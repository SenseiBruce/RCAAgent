# RCA Agent Configuration
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
GIT_DEFAULT_BRANCH=main
GIT_MAX_COMMITS=50
GIT_REPO_URL=https://github.com/SenseiBruce/RCAAgent
LOG_MAX_FILE_SIZE_MB=100
LOG_LEVEL=INFO

# Prompt Overrides (optional - set to custom file path)
RCA_PROMPT_PATH=
CHAT_SYSTEM_PROMPT_PATH=
FIX_PROMPT_PATH=

# GitHub Token (required for Auto-Fix & PR creation)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Guardrails
GUARDRAIL_MAX_INPUT_LENGTH=50000
GUARDRAIL_MAX_LOG_LINES=5000
GUARDRAIL_MAX_HISTORY=20
GUARDRAIL_MAX_CONCURRENT=5
GUARDRAIL_BLOCKED_PATTERNS=
GUARDRAIL_ALLOW_AUTOFIX=true
GUARDRAIL_REQUIRE_APPROVAL=false
GUARDRAIL_MAX_FILES_PER_FIX=10
GUARDRAIL_ALLOWED_REPOS=
